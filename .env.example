DATABASE_URL="postgresql://resume:resume@127.0.0.1:5433/ai_resume_builder"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
GOOGLE_GENERATIVE_AI_API_KEY=""
# Optional override; default in code is gemini-flash-latest
GEMINI_MODEL="gemini-flash-latest"
# Vercel Blob — store shared resume PDFs (optional; without it PDFs render on demand)
# Create at https://vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=""

# --- LinkedIn via Apify (recommended) ---
# 1. Open https://console.apify.com/settings/integrations
# 2. Copy your personal API token
# 3. Restart `npm run dev` after saving
APIFY_TOKEN=""
# Optional — defaults to HarvestAPI LinkedIn Profile Scraper
# APIFY_LINKEDIN_ACTOR_ID="harvestapi~linkedin-profile-scraper"
# APIFY_LINKEDIN_PROFILE_MODE="Profile details no email ($4 per 1k)"

# Alternative: generic URL-in JSON-out connector (non-Apify)
# LINKEDIN_CONNECTOR_URL=""
# LINKEDIN_CONNECTOR_API_KEY=""
