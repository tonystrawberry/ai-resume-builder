{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-resume-builder.local/schemas/master-resume.json",
  "title": "MasterResume",
  "type": "object",
  "additionalProperties": false,
  "required": ["identity", "experience", "education", "skills", "projects", "meta"],
  "properties": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fullName"],
      "properties": {
        "fullName": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "photoUrl": { "type": "string" },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },
    "summary": { "type": "string" },
    "experience": {
      "type": "array",
      "items": { "$ref": "#/$defs/experienceItem" }
    },
    "education": {
      "type": "array",
      "items": { "$ref": "#/$defs/educationItem" }
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillItem" }
    },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/projectItem" }
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "provenance"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "issuer": { "type": "string" },
          "date": { "type": "string" },
          "provenance": { "$ref": "#/$defs/provenance" },
          "sourceRefs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "gaps"],
      "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["section", "severity", "message"],
            "properties": {
              "section": { "type": "string" },
              "path": { "type": "string" },
              "severity": { "enum": ["critical", "high", "medium", "low"] },
              "message": { "type": "string" }
            }
          }
        },
        "lastEnrichedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "$defs": {
    "provenance": {
      "type": "string",
      "enum": ["github", "linkedin", "user", "ai_suggested"]
    },
    "experienceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "company", "title", "bullets", "metrics", "provenance"],
      "properties": {
        "id": { "type": "string" },
        "company": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "current": { "type": "boolean" },
        "bullets": { "type": "array", "items": { "type": "string" } },
        "metrics": { "type": "array", "items": { "type": "string" } },
        "logoUrl": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "sourceRefs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "educationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "institution", "provenance"],
      "properties": {
        "id": { "type": "string" },
        "institution": { "type": "string" },
        "degree": { "type": "string" },
        "field": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "bullets": { "type": "array", "items": { "type": "string" } },
        "logoUrl": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "sourceRefs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "skillItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "provenance"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "sourceRefs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "projectItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "highlights", "technologies", "provenance"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "highlights": { "type": "array", "items": { "type": "string" } },
        "technologies": { "type": "array", "items": { "type": "string" } },
        "provenance": { "$ref": "#/$defs/provenance" },
        "sourceRefs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
